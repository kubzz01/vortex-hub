local placeId = 93978595733734 -- ID game kamu

-- [PERBAIKAN LOGIKA]: Menggunakan ~= (tidak sama dengan) agar script HANYA berjalan di game kamu
if game.PlaceId ~= placeId then
    warn("Script tidak berjalan di game ini")
    return -- Berhenti jika dimainkan di game lain
end

local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/kubzz01/vortex-hub/refs/heads/main/source"))()

-- Menampilkan notifikasi Loading
OrionLib:MakeNotification({
    Name = "Vortex Hub Loading...",
    Content = "Harap tunggu sebentar",
    -- Diubah ke rbxthumb agar gambar notifikasi muncul
    Image = "rbxthumb://type=Asset&id=75062134749633&w=150&h=150",
    Time = 3
})

wait(3)

-- Membuat Window dengan Logo dan animasi Intro
local Window = OrionLib:MakeWindow({
    Name = "Vortex Hub | Violence District",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "VortexHubConfig",
    IntroEnabled = true,
    IntroText = "Vortex Hub",
    -- Diubah ke rbxthumb agar animasi logo intro muncul
    IntroIcon = "rbxthumb://type=Asset&id=75062134749633&w=150&h=150",
    ShowIcon = true,
    -- Diubah ke rbxthumb agar logo di pojok kiri atas menu muncul
    Icon = "rbxthumb://type=Asset&id=75062134749633&w=150&h=150",
    Dragable = true  
})

-- Tab Universal Scripts
local UniversalTab = Window:MakeTab({
    Name = "Universal Scripts",
    -- Diubah ke rbxthumb dengan ID baru kamu agar ikon tab muncul
    Icon = "rbxthumb://type=Asset&id=75062134749633&w=150&h=150",
