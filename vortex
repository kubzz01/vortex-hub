local placeId = 93978595733734 -- ganti dengan PlaceId game kamu

if game.PlaceId == placeId then
    warn("Script tidak berjalan di game ini")
end

local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/kubzz01/vortex-hub/refs/heads/main/source"))()

-- Menampilkan notifikasi Loading
OrionLib:MakeNotification({
    Name = "Vortex Hub Loading...",
    Content = "Harap tunggu sebentar",
    Image = "rbxassetid://80188749139013",
    Time = 3
})

wait(3)

-- Membuat Window dengan Logo dan animasi Intro
local Window = OrionLib:MakeWindow({
    Name = "Vortex Hub | Violence District",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "VortexHubConfig",
    IntroEnabled = true,
    IntroText = "Vortex Hub",
    IntroIcon = "rbxassetid://80188749139013",
    ShowIcon = true,
    Icon = "rbxassetid://80188749139013",
    Dragable = true  
})


-- Tab Universal Scripts
local UniversalTab = Window:MakeTab({
    Name = "Universal Scripts",
